{
  "manifest_version": 3,
  "name": "Likely",
  "version": "1.0.0",
  "description": "Invites people from an already-open Facebook reaction dialog at a controlled pace.",
  "permissions": ["activeTab", "storage", "scripting"],
  "host_permissions": ["https://www.facebook.com/*", "https://web.facebook.com/*"],
  "icons": {
    "16": "icons/likely-16.png",
    "32": "icons/likely-32.png",
    "48": "icons/likely-48.png",
    "128": "icons/likely-128.png"
  },
  "action": {
    "default_title": "Likely",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/likely-16.png",
      "32": "icons/likely-32.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://www.facebook.com/*", "https://web.facebook.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
